{
  "name": "discord-broadcast",
  "version": "1.0.0",
  "description": "Real-time Discord voice broadcast — 1 source to N channels",
  "main": "src/index.js",
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "start": "node src/index.js",
    "register": "node scripts/register-commands.js",
